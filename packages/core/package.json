{
  "name": "@master-security/core",
  "version": "1.0.0",
  "description": "Master Security Framework - TypeScript SDK",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./auth": {
      "import": "./dist/auth/index.js",
      "require": "./dist/auth/index.cjs",
      "types": "./dist/auth/index.d.ts"
    },
    "./web": {
      "import": "./dist/web/index.js",
      "require": "./dist/web/index.cjs",
      "types": "./dist/web/index.d.ts"
    },
    "./api": {
      "import": "./dist/api/index.js",
      "require": "./dist/api/index.cjs",
      "types": "./dist/api/index.d.ts"
    },
    "./ai": {
      "import": "./dist/ai/index.js",
      "require": "./dist/ai/index.cjs",
      "types": "./dist/ai/index.d.ts"
    },
    "./crypto": {
      "import": "./dist/crypto/index.js",
      "require": "./dist/crypto/index.cjs",
      "types": "./dist/crypto/index.d.ts"
    },
    "./honeypot": {
      "import": "./dist/honeypot/index.js",
      "require": "./dist/honeypot/index.cjs",
      "types": "./dist/honeypot/index.d.ts"
    },
    "./file": {
      "import": "./dist/file/index.js",
      "require": "./dist/file/index.cjs",
      "types": "./dist/file/index.d.ts"
    },
    "./network": {
      "import": "./dist/network/index.js",
      "require": "./dist/network/index.cjs",
      "types": "./dist/network/index.d.ts"
    },
    "./cloud": {
      "import": "./dist/cloud/index.js",
      "require": "./dist/cloud/index.cjs",
      "types": "./dist/cloud/index.d.ts"
    },
    "./monitoring": {
      "import": "./dist/monitoring/index.js",
      "require": "./dist/monitoring/index.cjs",
      "types": "./dist/monitoring/index.d.ts"
    },
    "./defensive": {
      "import": "./dist/defensive/index.js",
      "require": "./dist/defensive/index.cjs",
      "types": "./dist/defensive/index.d.ts"
    },
    "./enterprise": {
      "import": "./dist/enterprise/index.js",
      "require": "./dist/enterprise/index.cjs",
      "types": "./dist/enterprise/index.d.ts"
    },
    "./integrations": {
      "import": "./dist/integrations/index.js",
      "require": "./dist/integrations/index.cjs",
      "types": "./dist/integrations/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^1.4.0",
    "@opentelemetry/api": "^1.9.0",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
